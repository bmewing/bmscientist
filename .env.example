DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
EXA_API_KEY=your_exa_api_key
HF_TOKEN=your_huggingface_token

# Base directory for raw data, LanceDB, graph files, pricing cache, and co-scientist outputs.
BMSCIENTIST_DATA_DIR=./data

# Optional explicit LanceDB override. If omitted, defaults to BMSCIENTIST_DATA_DIR/lancedb.
# LANCEDB_PATH=./data/lancedb

EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
REQUEST_TIMEOUT_SECONDS=60
SKIP_FETCH_DOMAINS=sciencedirect.com

# Optional external skill integrations
EPISUITE_API_BASE_URL=https://episuite.dev
RXN4CHEMISTRY_API_KEY=
RXN4CHEMISTRY_PROJECT_ID=
# Optional: if PROJECT_ID is omitted, the RXN skill can reuse or create this project name.
RXN4CHEMISTRY_PROJECT_NAME=bmscientist
RXN4CHEMISTRY_BASE_URL=https://rxn.res.ibm.com
# Optional retrosynthesis model release string. Leave blank to use the wrapper default (`2020-07-01`).
RXN4CHEMISTRY_RETROSYNTHESIS_MODEL=
# Optional freemium molecule-pricing provider used by `molecule_pricing_optional`.

# Exa retrieval controls
EXA_SEARCH_CONTENT_TEXT_CHARS=8000
EXA_CONTENTS_INITIAL_TEXT_CHARS=12000
EXA_CONTENTS_DEEP_TEXT_CHARS=50000
EXA_HIGHLIGHTS_MAX_CHARS=2000
EXA_ENABLE_SEARCH_CONTENTS=true
EXA_ENABLE_CONTENTS_FOLLOWUP=true
EXA_ENABLE_DIRECT_FETCH_FALLBACK=true
EXA_DEFAULT_SEARCH_TYPE=auto
EXA_REFLECTION_SEARCH_TYPE=fast
EXA_DEFAULT_MAX_AGE_HOURS=168
EXA_NEWS_MAX_AGE_HOURS=24
EXA_DEEP_FETCH_MIN_SCORE=0.78
EXA_DEEP_FETCH_MAX_PER_QUERY=2
EXA_DEEP_FETCH_MAX_PER_RUN=10
EXA_SEARCH_CATEGORY=
EXA_NEWS_DOMAINS=polymart.info

# ---------------------------------------------------------------------------
# Default chat model configuration
# ---------------------------------------------------------------------------

# Simple model-only configuration still works.
CHAT_MODEL=deepseek-v4-flash

# Optional structured request profile for DeepSeek OpenAI-format thinking mode.
# This maps to:
#   extra_body={"thinking":{"type":"enabled|disabled"}}
#   reasoning_effort="high|max"
#
# If both CHAT_MODEL and CHAT_PROFILE are present, CHAT_PROFILE.model wins.
# timeout_seconds is optional per profile and overrides REQUEST_TIMEOUT_SECONDS for that role.
# Example:
# CHAT_PROFILE={"model":"deepseek-v4-pro","thinking":{"enabled":true,"effort":"high"},"timeout_seconds":90}
CHAT_PROFILE=

# ---------------------------------------------------------------------------
# Agent-specific model overrides
# ---------------------------------------------------------------------------

# You can keep using the model-only keys:
GENERATION_CHAT_MODEL=deepseek-v4-pro
REFLECTION_CHAT_MODEL=deepseek-v4-flash
PLANNING_CHAT_MODEL=deepseek-v4-pro
RANKING_CHAT_MODEL=deepseek-v4-pro
EVOLUTION_CHAT_MODEL=deepseek-v4-pro
PROXIMITY_CHAT_MODEL=deepseek-v4-pro
META_REVIEW_CHAT_MODEL=deepseek-v4-pro
MARKET_VOLUME_ESTIMATION_CHAT_MODEL=deepseek-v4-pro

# Or switch individual roles to structured request profiles.
# If both *_CHAT_MODEL and *_CHAT_PROFILE are present, *_CHAT_PROFILE.model wins.
# timeout_seconds is optional per profile and overrides REQUEST_TIMEOUT_SECONDS for that role.
#
# Example profiles:
# GENERATION_CHAT_PROFILE={"model":"deepseek-v4-flash","thinking":{"enabled":false},"timeout_seconds":45}
# REFLECTION_CHAT_PROFILE={"model":"deepseek-v4-pro","thinking":{"enabled":true,"effort":"high"},"timeout_seconds":120}
# PLANNING_CHAT_PROFILE={"model":"deepseek-v4-pro","thinking":{"enabled":true,"effort":"max"},"timeout_seconds":150}
# RANKING_CHAT_PROFILE={"model":"deepseek-v4-pro","thinking":{"enabled":true,"effort":"high"},"timeout_seconds":120}
# EVOLUTION_CHAT_PROFILE={"model":"deepseek-v4-pro","thinking":{"enabled":true,"effort":"max"},"timeout_seconds":150}
# PROXIMITY_CHAT_PROFILE={"model":"deepseek-v4-pro","thinking":{"enabled":true,"effort":"high"},"timeout_seconds":90}
# META_REVIEW_CHAT_PROFILE={"model":"deepseek-v4-pro","thinking":{"enabled":true,"effort":"max"},"timeout_seconds":150}
# MARKET_VOLUME_ESTIMATION_CHAT_PROFILE={"model":"deepseek-v4-pro","thinking":{"enabled":true,"effort":"max"},"timeout_seconds":180}
GENERATION_CHAT_PROFILE=
REFLECTION_CHAT_PROFILE=
PLANNING_CHAT_PROFILE=
RANKING_CHAT_PROFILE=
EVOLUTION_CHAT_PROFILE=
PROXIMITY_CHAT_PROFILE=
META_REVIEW_CHAT_PROFILE=
MARKET_VOLUME_ESTIMATION_CHAT_PROFILE=
